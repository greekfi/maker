# Bebop maker credentials (from the Bebop team)
BEBOP_MARKETMAKER=
BEBOP_AUTHORIZATION=

# Signing — PRIVATE_KEY MUST match MAKER_ADDRESS (the address registered with
# Bebop), or every quote is rejected. The maker warns at startup if they differ.
PRIVATE_KEY=
MAKER_ADDRESS=

# Chain + factory (where options are discovered)
CHAIN_ID=8453
CHAIN=base
RPC_URL=https://mainnet.base.org
FACTORY=0xa77d556536295be287facc7bb4a439d96a8227db
FROM_BLOCK=46876834

# Price
PRICE_PER_TOKEN=10

# Optional: only quote these option addresses (comma-separated)
OPTION_ONLY=
