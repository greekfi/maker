# === Identity (required for bebop mode and signed /quote responses) ===
PRIVATE_KEY=
MAKER_ADDRESS=

# === Bebop credentials (bebop + relay modes) ===
BEBOP_MARKETMAKER=
BEBOP_AUTHORIZATION=

# === Chains ===
# direct mode defaults to every chain in factories.json; restrict with:
#CHAIN_IDS=8453,42161
# bebop mode is single-chain:
#CHAIN_ID=8453
#CHAIN=base
# relay mode upstream feeds:
#BEBOP_CHAINS=ethereum,base,arbitrum

# === RPC overrides (public defaults work; paid keys give better tail latency) ===
#RPC_ETHEREUM=
#RPC_BASE=
#RPC_ARBITRUM=
#RPC_UNICHAIN=
#RPC_INK=

# === Ports ===
#HTTP_PORT=3010
#WS_PORT=3011
#RELAY_PORT=3004

# === SSVI surface (replaces the node IV_SKEW/IV_CURVATURE smile) ===
#SVI_ATM_IV=0.8          # ATM vol anchor (DEFAULT_IV also accepted)
#SVI_RHO=-0.3            # skew, (-1, 1); negative tilts puts rich
#SVI_ETA=1.0             # smile amplitude
#SVI_GAMMA=0.4           # smile flattening with maturity, (0, 1)
#SVI_MIN_IV=0.1
#SVI_MAX_IV=3.0
#RISK_FREE_RATE=0.05

# === Event sync ===
#LOG_CHUNK_SIZE=10000    # getLogs block-range cap (10k = Base public limit)
#SYNC_INTERVAL_MS=30000
#LOG_CHUNK_PAUSE_MS=100
#FACTORIES_JSON=         # defaults to ./factories.json (repo root)

# === Misc ===
#SPOT_POLL_INTERVAL=30
#WS_UPDATE_INTERVAL=5000
#PRICE_OVERRIDE_USD=     # debug: force every option to (mid-1%, mid+1%)
#OPTION_ONLY=            # bebop mode: comma-separated option address filter
#LOG_LEVEL=INFO
