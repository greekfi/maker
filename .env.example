# === Bebop maker credentials (required) ===
# Issued by the Bebop team. The same values the node market-maker uses.
BEBOP_MARKETMAKER=
BEBOP_AUTHORIZATION=

# === Signing identity (required to sign quotes) ===
PRIVATE_KEY=
MAKER_ADDRESS=

# === Chain (bebop mode is single-chain) ===
CHAIN_ID=8453
CHAIN=base

# === Price ===
PRICE_PER_TOKEN=10        # flat USD price per option token

# === Optional ===
#OPTION_ONLY=             # comma-separated option addresses to quote (default: all)
#RPC_BASE=               # RPC override (public default works)
#FACTORIES_JSON=         # defaults to ./factories.json
#LOG_LEVEL=INFO
